rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function isPlatformAdmin() {
      return isSignedIn() &&
        request.auth.token.platformAdmin == true;
    }

    function membershipDoc(orgId) {
      return get(/databases/$(database)/documents/organizations/$(orgId)/memberships/$(uid()));
    }

    function isOrgMember(orgId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/organizations/$(orgId)/memberships/$(uid())) &&
        membershipDoc(orgId).data.status == 'active';
    }

    function hasOrgRole(orgId, role) {
      return isOrgMember(orgId) && role in membershipDoc(orgId).data.roles;
    }

    function orgDoc(orgId) {
      return get(/databases/$(database)/documents/organizations/$(orgId));
    }

    function orgTypeValue(orgId) {
      return orgDoc(orgId).data.type;
    }

    function isContractorOrg(orgId) {
      return orgTypeValue(orgId) == 'contractor';
    }

    function isSupplierOrg(orgId) {
      return orgTypeValue(orgId) == 'supplier';
    }

    function isContractorCompanyOwner(orgId) {
      return hasOrgRole(orgId, 'contractorCompanyOwner');
    }

    function isSupplierOwner(orgId) {
      return hasOrgRole(orgId, 'supplierOwner');
    }

    function canManageOrgMemberships(orgId) {
      return isPlatformAdmin() ||
        (isContractorOrg(orgId) && isContractorCompanyOwner(orgId)) ||
        (isSupplierOrg(orgId) && isSupplierOwner(orgId));
    }

    function canInviteOrgMembers(orgId) {
      return canManageOrgMemberships(orgId) ||
        (isContractorOrg(orgId) && hasOrgRole(orgId, 'procurementManager'));
    }

    function invitationRoleAllowedForActor(orgId, role) {
      return canManageOrgMemberships(orgId) ||
        (hasOrgRole(orgId, 'procurementManager') &&
          role in ['engineer', 'contractorViewer']);
    }

    function isProcurementManager(orgId) {
      return hasOrgRole(orgId, 'procurementManager');
    }

    function contractorOrgRoles() {
      return [
        'contractorCompanyOwner',
        'procurementManager',
        'projectManager',
        'engineer',
        'contractorViewer'
      ];
    }

    function supplierOrgRoles() {
      return [
        'supplierOwner',
        'supplierSalesManager',
        'supplierSalesRep',
        'supplierOps',
        'supplierViewer'
      ];
    }

    function roleValidForOrg(orgId, role) {
      return role != 'platformAdmin' && (
        (isContractorOrg(orgId) && role in contractorOrgRoles()) ||
        (isSupplierOrg(orgId) && role in supplierOrgRoles())
      );
    }

    function membershipRolesValid(orgId, roles) {
      return roles is list &&
        roles.size() == 1 &&
        roleValidForOrg(orgId, roles[0]);
    }

    function membershipCoreFieldsPreserved() {
      return request.resource.data.orgId == resource.data.orgId &&
        request.resource.data.orgType == resource.data.orgType;
    }

    function membershipOwnerDemotionBlocked(orgId, memberUid) {
      let org = orgDoc(orgId).data;
      let oldRoles = resource.data.roles;
      let newRoles = request.resource.data.roles;
      let demotingContractorOwner =
        'contractorCompanyOwner' in oldRoles &&
        !('contractorCompanyOwner' in newRoles);
      let demotingSupplierOwner =
        'supplierOwner' in oldRoles &&
        !('supplierOwner' in newRoles);
      return (demotingContractorOwner || demotingSupplierOwner) &&
        org.keys().hasAny(['ownerUid']) &&
        org.ownerUid == memberUid &&
        !isPlatformAdmin();
    }

    function membershipUpdateAllowed(orgId, memberUid) {
      return resource.data.orgId == orgId &&
        request.resource.data.orgId == orgId &&
        membershipCoreFieldsPreserved() &&
        changedOnly(['roles', 'updatedAt', 'updatedByUid']) &&
        request.resource.data.updatedByUid == uid() &&
        membershipRolesValid(orgId, request.resource.data.roles) &&
        !membershipOwnerDemotionBlocked(orgId, memberUid) && (
          (isPlatformAdmin()) ||
          (canManageOrgMemberships(orgId) && memberUid != uid())
        );
    }

    function membershipSelfOwnerCreateBlocked(memberUid) {
      return memberUid == uid() && (
        'contractorCompanyOwner' in request.resource.data.roles ||
        'supplierOwner' in request.resource.data.roles
      );
    }

    function invitationDoc(inviteId) {
      return get(/databases/$(database)/documents/invitations/$(inviteId));
    }

    function membershipInviteAcceptCreateAllowed(orgId, memberUid) {
      let inviteId = request.resource.data.acceptedInvitationId;
      let invite = invitationDoc(inviteId);
      return memberUid == uid() &&
        request.resource.data.keys().hasAny(['acceptedInvitationId']) &&
        invite.data.status == 'pending' &&
        invite.data.email == request.auth.token.email &&
        invite.data.orgId == orgId &&
        request.resource.data.orgId == orgId &&
        request.resource.data.status == 'active' &&
        request.resource.data.roles.size() == 1 &&
        request.resource.data.roles[0] == invite.data.role &&
        membershipRolesValid(orgId, request.resource.data.roles);
    }

    function membershipCreateAllowed(orgId, memberUid) {
      return membershipInviteAcceptCreateAllowed(orgId, memberUid) ||
        membershipOwnerBootstrapCreateAllowed(orgId, memberUid) || (
        isPlatformAdmin() &&
        request.resource.data.orgId == orgId &&
        request.resource.data.orgType == orgTypeValue(orgId) &&
        membershipRolesValid(orgId, request.resource.data.roles) &&
        !membershipSelfOwnerCreateBlocked(memberUid)
      );
    }

    function projectDoc(projectId) {
      return get(/databases/$(database)/documents/projects/$(projectId));
    }

    function projectDataOrgId(data) {
      return data.keys().hasAny(['orgId']) &&
        data.orgId is string &&
        data.orgId.size() > 0
        ? data.orgId
        : (
          data.keys().hasAny(['ownerUid']) &&
          data.ownerUid is string &&
          data.ownerUid.size() > 0
            ? data.ownerUid
            : ''
        );
    }

    function projectOrgId(projectId) {
      return projectDataOrgId(projectDoc(projectId).data);
    }

    function contractorOrgCanReadProject(data) {
      let orgId = projectDataOrgId(data);
      return orgId != '' && (
        hasOrgRole(orgId, 'contractorCompanyOwner') ||
        hasOrgRole(orgId, 'procurementManager')
      );
    }

    function isProjectManagerFor(projectId) {
      return exists(/databases/$(database)/documents/projects/$(projectId)/assignments/$(uid())) &&
        get(/databases/$(database)/documents/projects/$(projectId)/assignments/$(uid())).data.role == 'projectManager';
    }

    function canManageProjectAssignments(projectId) {
      return isPlatformAdmin() ||
        projectDoc(projectId).data.ownerUid == uid() ||
        (projectOrgId(projectId) != '' &&
          canManageOrgMemberships(projectOrgId(projectId))) ||
        isProjectManagerFor(projectId);
    }

    function projectAssignmentRolesValid(role) {
      return role in [
        'projectManager',
        'engineer',
        'procurementManager',
        'contractorViewer'
      ];
    }

    function projectAssignmentCreateAllowed(projectId, assignUid) {
      let orgOk = projectOrgId(projectId) == '' ||
        request.resource.data.orgId == projectOrgId(projectId);
      return canManageProjectAssignments(projectId) &&
        orgOk &&
        !(assignUid == uid() &&
          request.resource.data.role == 'projectManager') &&
        request.resource.data.projectId == projectId &&
        request.resource.data.uid == assignUid &&
        projectAssignmentRolesValid(request.resource.data.role);
    }

    function projectAssignmentUpdateAllowed(projectId, assignUid) {
      return canManageProjectAssignments(projectId) &&
        resource.data.projectId == projectId &&
        resource.data.uid == assignUid &&
        request.resource.data.projectId == resource.data.projectId &&
        request.resource.data.uid == resource.data.uid &&
        request.resource.data.orgId == resource.data.orgId &&
        !(assignUid == uid() &&
          request.resource.data.role == 'projectManager') &&
        projectAssignmentRolesValid(request.resource.data.role) &&
        changedOnly([
          'role',
          'updatedAt',
          'displayName',
          'email',
          'assignedByUid'
        ]);
    }

    function projectAssignmentReadAllowed(projectId, assignUid) {
      return isPlatformAdmin() ||
        assignUid == uid() ||
        projectDoc(projectId).data.ownerUid == uid() ||
        canManageProjectAssignments(projectId);
    }

    function invitationCreateAllowed() {
      let data = request.resource.data;
      return data.orgId is string &&
        canInviteOrgMembers(data.orgId) &&
        invitationRoleAllowedForActor(data.orgId, data.role) &&
        data.status == 'pending' &&
        data.invitedByUid == uid() &&
        data.email is string &&
        data.email.size() > 0 &&
        membershipRolesValid(data.orgId, [data.role]) &&
        !(data.email == request.auth.token.email && (
          data.role == 'contractorCompanyOwner' ||
          data.role == 'supplierOwner'
        ));
    }

    function invitationReadAllowed() {
      return isPlatformAdmin() ||
        canManageOrgMemberships(resource.data.orgId) ||
        (resource.data.status == 'pending' &&
          resource.data.email == request.auth.token.email);
    }

    function invitationUpdateAllowed() {
      return (
        isPlatformAdmin() ||
        (canManageOrgMemberships(resource.data.orgId) &&
          resource.data.status == 'pending' &&
          request.resource.data.status == 'cancelled' &&
          request.resource.data.email == resource.data.email &&
          request.resource.data.role == resource.data.role &&
          request.resource.data.orgId == resource.data.orgId &&
          changedOnly([
            'status',
            'updatedAt',
            'cancelledAt',
            'deliveryStatus'
          ]))
      ) || (
        canManageOrgMemberships(resource.data.orgId) &&
        resource.data.status == 'pending' &&
        request.resource.data.status == 'pending' &&
        request.resource.data.email == resource.data.email &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.orgId == resource.data.orgId &&
        changedOnly(['deliveryStatus', 'updatedAt'])
      ) || (
        resource.data.status == 'pending' &&
        resource.data.email == request.auth.token.email &&
        request.resource.data.status == 'accepted' &&
        request.resource.data.email == resource.data.email &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.orgId == resource.data.orgId &&
        request.resource.data.acceptedByUid == uid() &&
        changedOnly([
          'status',
          'updatedAt',
          'deliveryStatus',
          'acceptedByUid',
          'acceptedAt'
        ])
      );
    }

    function hasProjectAuditRead(projectId) {
      return isPlatformAdmin() ||
        projectDoc(projectId).data.ownerUid == uid() ||
        isProjectManagerFor(projectId) ||
        exists(/databases/$(database)/documents/projects/$(projectId)/assignments/$(uid()));
    }

    function auditEventCreateAllowed() {
      return isSignedIn() &&
        request.resource.data.actorUid == uid() &&
        request.resource.data.entityType is string &&
        request.resource.data.entityId is string &&
        request.resource.data.action is string &&
        request.resource.data.summaryHebrew is string;
    }

    function auditEventReadAllowed() {
      return isPlatformAdmin() ||
        (resource.data.keys().hasAny(['orgId']) &&
          resource.data.orgId is string &&
          canManageOrgMemberships(resource.data.orgId)) ||
        (resource.data.keys().hasAny(['projectId']) &&
          resource.data.projectId is string &&
          hasProjectAuditRead(resource.data.projectId));
    }

    function hasProjectAccess(projectId) {
      return isSignedIn() && (
        isPlatformAdmin() ||
        (
          exists(/databases/$(database)/documents/projects/$(projectId)) &&
          get(/databases/$(database)/documents/projects/$(projectId)).data.ownerUid == uid()
        ) ||
        exists(/databases/$(database)/documents/projects/$(projectId)/assignments/$(uid()))
      );
    }

    function isProjectAssignee(projectId) {
      return exists(/databases/$(database)/documents/projects/$(projectId)/assignments/$(uid()));
    }

    function supplierApprovedQuoteOwner(requestData) {
      return requestData.keys().hasAny(['approvedQuoteId']) &&
        requestData.approvedQuoteId is string &&
        requestData.approvedQuoteId.size() > 0 &&
        exists(/databases/$(database)/documents/supplierQuotes/$(requestData.approvedQuoteId)) &&
        get(/databases/$(database)/documents/supplierQuotes/$(requestData.approvedQuoteId)).data.supplierId == uid();
    }

    function supplierOrderShipFields() {
      return ['status', 'updatedAt', 'shippedAt', 'shippedBySupplierId'];
    }

    function supplierCanMarkOrderShipped() {
      return isSupplier() &&
        resource.data.customerId == request.resource.data.customerId &&
        supplierApprovedQuoteOwner(resource.data) &&
        resource.data.status in ['הוזמנה', 'ordered'] &&
        request.resource.data.status in ['נשלחה', 'shipped'] &&
        changedOnly(supplierOrderShipFields());
    }

    function organizationOwnerBootstrapAllowed(orgId) {
      return false;
    }

    function membershipOwnerBootstrapCreateAllowed(orgId, memberUid) {
      return false;
    }

    function validProjectStatus(status) {
      return status in ['active', 'archived', 'completed', 'deletionPending'];
    }

    function projectDeletionFieldsValid() {
      return request.resource.data.status != 'deletionPending' ||
        (
          request.resource.data.deletionScheduledFor is timestamp &&
          request.resource.data.deletionScheduledFor > request.time
        );
    }

    function projectCreateOrgId() {
      return request.resource.data.keys().hasAny(['orgId']) &&
        request.resource.data.orgId is string &&
        request.resource.data.orgId.size() > 0
        ? request.resource.data.orgId
        : request.resource.data.ownerUid;
    }

    function projectCreateRoleAllowed() {
      let orgId = projectCreateOrgId();
      return hasOrgRole(orgId, 'contractorCompanyOwner') &&
        (
          request.resource.data.ownerUid == uid() ||
          request.resource.data.ownerUid == orgId
        );
    }

    function projectOwnerCreateAllowed() {
      return userHasActivePlatformAccess() &&
        projectCreateRoleAllowed() &&
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        validProjectStatus(request.resource.data.status) &&
        request.resource.data.keys().hasAll(['createdAt', 'updatedAt']);
    }

    function projectOwnerUpdateAllowed() {
      return resource.data.ownerUid == uid() &&
        request.resource.data.ownerUid == resource.data.ownerUid &&
        validProjectStatus(request.resource.data.status) &&
        projectDeletionFieldsValid();
    }

    function projectAdminCreateAllowed() {
      return request.resource.data.ownerUid is string &&
        request.resource.data.ownerUid.size() > 0 &&
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        validProjectStatus(request.resource.data.status);
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(uid()));
    }

    function isCustomer() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(uid())) &&
        userDoc().data.userType in ['privateCustomer', 'commercialCustomer'];
    }

    function isSupplier() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(uid())) &&
        userDoc().data.userType in ['privateSupplier', 'commercialSupplier'];
    }

    function hasInviteConstraints(data) {
      return (data.keys().hasAny(['invitedSupplierIds']) &&
          data.invitedSupplierIds.size() > 0) ||
        (data.keys().hasAny(['invitedSupplierOrgIds']) &&
          data.invitedSupplierOrgIds.size() > 0) ||
        (data.keys().hasAny(['invitedSupplierNames']) &&
          data.invitedSupplierNames.size() > 0);
    }

    function requestOpenToAllSuppliers(data) {
      return data.keys().hasAny(['openToAllSuppliers']) &&
        data.openToAllSuppliers == true;
    }

    function activeSupplierOrgMembership(orgId) {
      return exists(/databases/$(database)/documents/organizations/$(orgId)/memberships/$(uid())) &&
        get(/databases/$(database)/documents/organizations/$(orgId)/memberships/$(uid())).data.status == 'active' &&
        isSupplierOrg(orgId);
    }

    function supplierInvitedByOrg(data) {
      return data.keys().hasAny(['invitedSupplierOrgIds']) &&
        data.invitedSupplierOrgIds is list &&
        (
          (data.invitedSupplierOrgIds.size() > 0 &&
            activeSupplierOrgMembership(data.invitedSupplierOrgIds[0])) ||
          (data.invitedSupplierOrgIds.size() > 1 &&
            activeSupplierOrgMembership(data.invitedSupplierOrgIds[1])) ||
          (data.invitedSupplierOrgIds.size() > 2 &&
            activeSupplierOrgMembership(data.invitedSupplierOrgIds[2])) ||
          (data.invitedSupplierOrgIds.size() > 3 &&
            activeSupplierOrgMembership(data.invitedSupplierOrgIds[3])) ||
          (data.invitedSupplierOrgIds.size() > 4 &&
            activeSupplierOrgMembership(data.invitedSupplierOrgIds[4]))
        );
    }

    function contractorOrgCanReadRequest(data) {
      let orgId = requestContractorOrgId(data);
      return orgId != '' && (
        hasOrgRole(orgId, 'contractorCompanyOwner') ||
        hasOrgRole(orgId, 'procurementManager')
      );
    }

    function supplierCanReadRequest(data) {
      return isSupplier() && (
        supplierResponded(data) ||
        (
          isOpenRequestStatus(data.status) && (
            requestOpenToAllSuppliers(data) ||
            (!hasInviteConstraints(data) &&
              !data.keys().hasAny(['openToAllSuppliers'])) ||
            (data.keys().hasAny(['invitedSupplierIds']) &&
              uid() in data.invitedSupplierIds) ||
            supplierInvitedByOrg(data)
          )
        )
      );
    }

    function supplierQuoteShippedUpdateAllowed() {
      return isSupplier() &&
        resource.data.supplierId == uid() &&
        resource.data.status in ['אושרה', 'approved'] &&
        request.resource.data.status in ['נשלחה', 'shipped'] &&
        changedOnly([
          'status',
          'seenOrderBySupplier',
          'updatedAt',
          'shippedAt',
          'shippedBySupplierId'
        ]);
    }

    function isOpenRequestStatus(status) {
      return status in ['נשלח', 'התקבלו הצעות', 'sent', 'quotesReceived'];
    }

    function changedOnly(fields) {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(fields);
    }

    function requestDoc(requestId) {
      return get(/databases/$(database)/documents/quoteRequests/$(requestId));
    }

    function supplierQuoteDoc(quoteId) {
      return get(/databases/$(database)/documents/supplierQuotes/$(quoteId));
    }

    function quoteHasCustomerId(data) {
      return data.keys().hasAny(['customerId']);
    }

    function quoteBelongsToCustomer(data) {
      return quoteHasCustomerId(data) && data.customerId == uid();
    }

    function supplierResponded(data) {
      return data.keys().hasAny(['supplierIdsResponded']) &&
        uid() in data.supplierIdsResponded;
    }

    function validUserType(userType) {
      return userType in [
        'privateCustomer',
        'commercialCustomer',
        'privateSupplier',
        'commercialSupplier'
      ];
    }

    function userHasActivePlatformAccess() {
      return !exists(/databases/$(database)/documents/users/$(uid())) ||
        !userDoc().data.keys().hasAny(['accountStatus']) ||
        userDoc().data.accountStatus == 'active';
    }

    function userCreateAllowed() {
      return request.resource.data.uid == uid() &&
        validUserType(request.resource.data.userType) &&
        request.resource.data.verified == false &&
        request.resource.data.email is string &&
        request.resource.data.email.size() > 0 &&
        (!request.resource.data.keys().hasAny(['accountStatus']) ||
          request.resource.data.accountStatus == 'pendingApproval');
    }

    function userAdminApprovalUpdateAllowed() {
      return changedOnly(['accountStatus', 'updatedAt']) &&
        request.resource.data.accountStatus in [
          'active',
          'blocked',
          'pendingApproval'
        ];
    }

    function userProfileUpdateAllowed() {
      return changedOnly([
          'name',
          'fullName',
          'phone',
          'city',
          'notes',
          'updatedAt'
        ]) &&
        request.resource.data.userType == resource.data.userType &&
        request.resource.data.verified == resource.data.verified &&
        request.resource.data.uid == resource.data.uid &&
        request.resource.data.email == resource.data.email;
    }

    function validQuoteRequestStatus(status) {
      return status in [
        'נשלח',
        'sent',
        'התקבלו הצעות',
        'quotesReceived',
        'הוזמנה',
        'ordered',
        'נשלחה',
        'shipped',
        'הושלמה',
        'completed',
        'בוטלה',
        'cancelled',
        'נסגר',
        'closed',
        'טיוטה',
        'draft',
        'ממתין לאישור רכש',
        'pendingApproval',
        'אושר על ידי רכש',
        'procurementApproved',
        'נדחה על ידי רכש',
        'procurementRejected'
      ];
    }

    function requestContractorOrgId(data) {
      return data.keys().hasAny(['contractorOrgId']) &&
        data.contractorOrgId is string &&
        data.contractorOrgId.size() > 0
        ? data.contractorOrgId
        : '';
    }

    function canApproveProcurementForRequest(data) {
      let orgId = requestContractorOrgId(data);
      return orgId != '' &&
        (hasOrgRole(orgId, 'procurementManager') ||
          hasOrgRole(orgId, 'contractorCompanyOwner'));
    }

    function procurementRfqApprovalUpdateAllowed() {
      return canApproveProcurementForRequest(resource.data) &&
        resource.data.status in [
          'ממתין לאישור רכש',
          'pendingApproval'
        ] &&
        request.resource.data.status in [
          'אושר על ידי רכש',
          'procurementApproved',
          'נדחה על ידי רכש',
          'procurementRejected'
        ] &&
        request.resource.data.customerId == resource.data.customerId &&
        changedOnly([
          'status',
          'procurementApprovedByUid',
          'procurementRejectedByUid',
          'procurementRejectionNote',
          'updatedAt'
        ]);
    }

    function procurementRfqSendUpdateAllowed() {
      return canApproveProcurementForRequest(resource.data) &&
        resource.data.status in [
          'אושר על ידי רכש',
          'procurementApproved'
        ] &&
        request.resource.data.status in ['נשלח', 'sent'] &&
        request.resource.data.customerId == resource.data.customerId &&
        changedOnly([
          'status',
          'submittedByUid',
          'invitedSupplierIds',
          'invitedSupplierNames',
          'invitedSupplierOrgIds',
          'openToAllSuppliers',
          'updatedAt'
        ]);
    }

    function validSupplierQuoteStatus(status) {
      return status in [
        'נשלח',
        'אושרה',
        'נדחתה',
        'נשלחה',
        'לא נבחרה',
        'לא מעודכנת'
      ];
    }

    function validRequestItem(item) {
      return item is map &&
        item.keys().hasAll([
          'productId',
          'productName',
          'category',
          'unitType',
          'quantity'
        ]) &&
        item.productId is string &&
        item.productId.size() > 0 &&
        item.productName is string &&
        item.productName.size() > 0 &&
        item.category is string &&
        item.unitType is string &&
        item.quantity is int &&
        item.quantity > 0 &&
        item.quantity <= 999999 &&
        (!('notes' in item) || item.notes is string) &&
        (!('variantId' in item) || item.variantId is string) &&
        (!('isCatalogMatched' in item) || item.isCatalogMatched is bool) &&
        (!('attributesSnapshot' in item) || item.attributesSnapshot is map);
    }

    function validRequestItemsList(items) {
      return items is list &&
        items.size() > 0 &&
        items.size() <= 200;
    }

    function requestItemsUnchangedOrValid() {
      return !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['items']) ||
        validRequestItemsList(request.resource.data.items);
    }

    function validSupplierQuoteItem(item) {
      return item is map &&
        item.keys().hasAll([
          'productId',
          'productName',
          'requestedQuantity',
          'unitPrice',
          'totalItemPrice'
        ]) &&
        item.productId is string &&
        item.productId.size() > 0 &&
        item.productName is string &&
        item.productName.size() > 0 &&
        item.requestedQuantity is int &&
        item.requestedQuantity > 0 &&
        item.requestedQuantity <= 999999 &&
        item.unitPrice is number &&
        item.unitPrice >= 0 &&
        item.totalItemPrice is number &&
        item.totalItemPrice >= 0 &&
        (!('variantId' in item) || item.variantId is string) &&
        (!('quotedSku' in item) || item.quotedSku is string) &&
        (!('quotedName' in item) || item.quotedName is string) &&
        (!('isExactMatch' in item) || item.isExactMatch is bool) &&
        (!('isAlternative' in item) || item.isAlternative is bool) &&
        (!('attributesSnapshot' in item) || item.attributesSnapshot is map);
    }

    function validSupplierQuoteItemsList(items) {
      return items is list &&
        items.size() > 0 &&
        items.size() <= 200;
    }

    function validLegacyRequestItem(data) {
      return data.keys().hasAll([
          'quoteRequestId',
          'productId',
          'productName',
          'quantity'
        ]) &&
        data.quoteRequestId is string &&
        data.productId is string &&
        data.productName is string &&
        data.quantity is int &&
        data.quantity > 0;
    }

    function validLegacySupplierQuoteItem(data) {
      return data.keys().hasAll([
          'supplierQuoteId',
          'productId',
          'productName',
          'requestedQuantity',
          'unitPrice',
          'totalItemPrice'
        ]) &&
        data.supplierQuoteId is string &&
        data.productId is string &&
        data.productName is string &&
        data.requestedQuantity is int &&
        data.requestedQuantity > 0 &&
        data.unitPrice is number &&
        data.unitPrice >= 0 &&
        data.totalItemPrice is number &&
        data.totalItemPrice >= 0;
    }

    function quoteRequestCreateAllowed() {
      return userHasActivePlatformAccess() &&
        request.resource.data.keys().hasAll([
          'customerId',
          'customerName',
          'customerPhone',
          'customerCity',
          'customerType',
          'status',
          'items',
          'createdAt'
        ]) &&
        request.resource.data.customerId == uid() &&
        request.resource.data.customerType == userDoc().data.userType &&
        request.resource.data.status in [
          'טיוטה',
          'draft',
          'ממתין לאישור רכש',
          'pendingApproval'
        ] &&
        validQuoteRequestStatus(request.resource.data.status) &&
        validRequestItemsList(request.resource.data.items) &&
        request.resource.data.supplierIdsResponded.size() == 0;
    }

    function customerQuoteStatusUpdateAllowed() {
      return !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['status']) ||
        request.resource.data.status in [
          'טיוטה',
          'draft',
          'ממתין לאישור רכש',
          'pendingApproval'
        ];
    }

    function supplierQuoteCreateAllowed() {
      let requestId = request.resource.data.requestId;
      let linkedRequest = requestDoc(requestId);
      return request.resource.data.keys().hasAll([
          'requestId',
          'supplierId',
          'supplierName',
          'status',
          'items',
          'createdAt'
        ]) &&
        request.resource.data.supplierId == uid() &&
        request.resource.data.status == 'נשלח' &&
        validSupplierQuoteStatus(request.resource.data.status) &&
        request.resource.data.customerId == linkedRequest.data.customerId &&
        validSupplierQuoteItemsList(request.resource.data.items) &&
        request.resource.data.totalPrice is number &&
        request.resource.data.totalPrice >= 0 &&
        (!('subtotal' in request.resource.data) ||
          (request.resource.data.subtotal is number &&
            request.resource.data.subtotal >= 0)) &&
        (!('deliveryCost' in request.resource.data) ||
          (request.resource.data.deliveryCost is number &&
            request.resource.data.deliveryCost >= 0)) &&
        (!('seenByCustomer' in request.resource.data) ||
          request.resource.data.seenByCustomer == false);
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (uid() == userId || isPlatformAdmin());
      allow create: if isSignedIn() && uid() == userId && userCreateAllowed();
      allow update: if isSignedIn() && (
        (uid() == userId && userProfileUpdateAllowed()) ||
        (isPlatformAdmin() && userAdminApprovalUpdateAllowed())
      );
      allow delete: if false;
    }

    match /products/{productId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /catalogCategories/{categoryId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /catalogProducts/{productId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /catalogVariants/{variantId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Catalog snapshot + match fields (variantId, isCatalogMatched, isExactMatch,
    // isAlternative, quotedSku, etc.) are stored inside embedded items[] on
    // quoteRequests and supplierQuotes — list size and scalar fields validated here.

    match /catalogMeta/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /appMeta/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Public supplier directory for contractor targeting (admin/backfill only).
    match /supplierDirectory/{supplierUid} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Contractor projects — owner-scoped; platform admin can manage all.
    match /projects/{projectId} {
      allow read: if isSignedIn() && (
        isPlatformAdmin() ||
        resource.data.ownerUid == uid() ||
        isProjectAssignee(projectId) ||
        contractorOrgCanReadProject(resource.data)
      );
      allow create: if isSignedIn() && (
        projectOwnerCreateAllowed() ||
        (isPlatformAdmin() && projectAdminCreateAllowed())
      );
      allow update: if isSignedIn() && (
        projectOwnerUpdateAllowed() ||
        isPlatformAdmin()
      );
      allow delete: if false;
    }

    match /organizations/{orgId} {
      allow read: if isSignedIn() && isOrgMember(orgId);
      allow create: if isPlatformAdmin();
      allow update: if isPlatformAdmin();
      allow delete: if false;
    }

    match /organizations/{orgId}/memberships/{memberUid} {
      allow read: if isSignedIn() && (
        memberUid == uid() ||
        resource.data.uid == uid() ||
        isOrgMember(orgId) ||
        isPlatformAdmin()
      );
      allow create: if isSignedIn() &&
        membershipCreateAllowed(orgId, memberUid);
      allow update: if isSignedIn() &&
        membershipUpdateAllowed(orgId, memberUid);
      allow delete: if isPlatformAdmin();
    }

    match /invitations/{inviteId} {
      allow read: if isSignedIn() && invitationReadAllowed();
      allow create: if isSignedIn() && invitationCreateAllowed();
      allow update: if isSignedIn() && invitationUpdateAllowed();
      allow delete: if isPlatformAdmin();
    }

    match /auditEvents/{eventId} {
      allow read: if isSignedIn() && auditEventReadAllowed();
      allow create: if isSignedIn() && auditEventCreateAllowed();
      allow update, delete: if false;
    }

    match /projects/{projectId}/assignments/{assignUid} {
      allow read: if isSignedIn() && (
        projectAssignmentReadAllowed(projectId, assignUid) ||
        resource.data.uid == uid()
      );
      allow create: if isSignedIn() &&
        projectAssignmentCreateAllowed(projectId, assignUid);
      allow update: if isSignedIn() &&
        projectAssignmentUpdateAllowed(projectId, assignUid);
      allow delete: if isSignedIn() &&
        canManageProjectAssignments(projectId);
    }

    match /quoteRequests/{requestId} {
      allow read: if isSignedIn() && (
        isPlatformAdmin() ||
        resource.data.customerId == uid() ||
        contractorOrgCanReadRequest(resource.data) ||
        supplierCanReadRequest(resource.data)
      );

      allow create: if isCustomer() && quoteRequestCreateAllowed();

      allow update: if isSignedIn() &&
        validQuoteRequestStatus(request.resource.data.status) &&
        requestItemsUnchangedOrValid() && (
        (
          isCustomer() &&
          resource.data.customerId == uid() &&
          request.resource.data.customerId == resource.data.customerId &&
          customerQuoteStatusUpdateAllowed() &&
          changedOnly([
            'items',
            'notes',
            'supplierIdsResponded',
            'seenBySupplierIds',
            'customerLastSeenStatus',
            'status',
            'approvedQuoteId',
            'tenderClosed',
            'updatedAt'
          ])
        ) ||
        (
          isSupplier() &&
          isOpenRequestStatus(resource.data.status) &&
          (
            changedOnly(['seenBySupplierIds']) ||
            (
              changedOnly([
                'status',
                'supplierIdsResponded',
                'lowestBid',
                'updatedAt'
              ]) &&
              request.resource.data.status == 'התקבלו הצעות' &&
              uid() in request.resource.data.supplierIdsResponded
            )
          ) &&
          request.resource.data.customerId == resource.data.customerId
        ) ||
        supplierCanMarkOrderShipped() ||
        procurementRfqApprovalUpdateAllowed() ||
        procurementRfqSendUpdateAllowed()
      );

      allow delete: if isCustomer() && resource.data.customerId == uid();
    }

    match /quoteRequestItems/{itemId} {
      allow read: if isSignedIn();
      allow create: if isCustomer() &&
        validLegacyRequestItem(request.resource.data) &&
        requestDoc(request.resource.data.quoteRequestId).data.customerId == uid();
      allow update, delete: if false;
    }

    match /supplierQuotes/{quoteId} {
      allow read: if isSignedIn() && (
        isPlatformAdmin() ||
        resource.data.supplierId == uid() ||
        quoteBelongsToCustomer(resource.data) ||
        requestDoc(resource.data.requestId).data.customerId == uid()
      );

      allow create: if isSupplier() &&
        supplierQuoteCreateAllowed() &&
        isOpenRequestStatus(requestDoc(request.resource.data.requestId).data.status);

      allow update: if isSignedIn() &&
        validSupplierQuoteStatus(request.resource.data.status) && (
        (
          isCustomer() &&
          (
            quoteBelongsToCustomer(resource.data) ||
            requestDoc(resource.data.requestId).data.customerId == uid()
          ) &&
          changedOnly(['status', 'seenOrderBySupplier', 'seenByCustomer'])
        ) ||
        (
          isSupplier() &&
          resource.data.supplierId == uid() &&
          (
            changedOnly(['seenOrderBySupplier']) ||
            supplierQuoteShippedUpdateAllowed()
          )
        )
      );
    }

    match /supplierQuoteItems/{itemId} {
      allow read: if isSignedIn();
      allow create: if isSupplier() &&
        validLegacySupplierQuoteItem(request.resource.data) &&
        supplierQuoteDoc(request.resource.data.supplierQuoteId).data.supplierId == uid();
      allow update, delete: if false;
    }
  }
}
